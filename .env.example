# Okruženje: development | production
NODE_ENV=development

# Port Express servera (Vite dev server proxy-ira /api na ovaj port)
PORT=3001

# Direktorijum sa CELOKUPNIM stanjem aplikacije: SQLite baza, slike, bekapi.
# Relativno u odnosu na server/ radni direktorijum ('../data' = data/ u korenu repoa).
# U Dockeru se postavlja apsolutno (npr. /app/data).
DATA_DIR=../data

# Dev olakšica: isključuje prijavu. Poštuje se SAMO kad NODE_ENV nije 'production' —
# u produkciji server ODBIJA da se pokrene ako je ovo uključeno (fail-safe).
AUTH_DISABLED=true

# Zajednička porodična lozinka za prijavu u produkciji.
AUTH_PASSWORD=promeni-me

# Tajna za potpisivanje session cookie-ja — najmanje 32 karaktera.
# Generisanje: openssl rand -hex 32  (ili bilo koji dugačak nasumičan string)
SESSION_SECRET=

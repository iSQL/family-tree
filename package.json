{
  "name": "family-tree",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client && npm run build -w server",
    "start": "npm run start -w server",
    "seed": "npm run seed -w server",
    "test": "vitest run",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "typescript": "~5.9.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.12"
  }
}
